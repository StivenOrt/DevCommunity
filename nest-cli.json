{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "common/Mail/templates/**/*.hbs",
        "watchAssets": true
      }
    ],
    "deleteOutDir": true,
    "assets": ["mails/templates/**/*",
    {"include": "**/*.hbs"}],
    "watchAssets": true
  }
}
